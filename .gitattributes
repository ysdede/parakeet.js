# === Line-ending policy ===
# All text files use LF in repo and working tree.
# Only Windows batch scripts use CRLF.

# Default: normalize all text files to LF
* text=auto eol=lf

# Windows command scripts — CRLF required
*.bat text eol=crlf
*.cmd text eol=crlf

